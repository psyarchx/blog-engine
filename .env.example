# Shared by every workspace package via the monorepo root.
# Copy to .env and tweak as needed.

# --- Database ---
DATABASE_URL=postgres://blog:blog@localhost:5432/blog_engine

# --- Auth (Phase 1) ---
# 32+ random chars. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# --- Email (Phase 1+) ---
RESEND_API_KEY=

# --- Public web ---
WEB_SITE_NAME=Blog Engine

# --- CMS ---
CMS_NAME=Blog CMS
CMS_ORIGIN=http://localhost:3001
CMS_WEB_ORIGIN=http://localhost:3000

# --- Seed (only read by `pnpm db:seed`) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin1234
SEED_ADMIN_NAME=Admin
